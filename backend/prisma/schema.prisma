generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum Role {
  PLAYER
  ADMIN
}

enum Timeframe {
  CURRENT
  PAST
  BOTH
}

enum CompetitionType {
  DOMESTIC_LEAGUE
  DOMESTIC_CUP
  CONTINENTAL_CLUB_COMPETITION
  INTERNATIONAL_TOURNAMENT
  GLOBAL_CLUB_CHAMPIONSHIP
  DOMESTIC_SUPER_CUP
  CONTINENTAL_SUPER_CUP
}

enum Region {
  EUROPE
  AFRICA
  ASIA
  NORTH_AMERICA
  SOUTH_AMERICA
  OCEANIA
  WORLD
}

enum PositionCategory {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum Position {
  GK
  RB
  CB
  LB
  CDM
  CM
  CAM
  RM
  LM
  RW
  LW
  CF
  ST
}

enum PreferredFoot {
  LEFT
  RIGHT
  BOTH
}

enum GameMode {
  STRIKES
  TOP_10
  PHOTO_GUESS
  LINEUP
}

enum LogicOperator {
  AND
  OR
}

enum QuestionScope {
  NATIONAL
  INTERNATIONAL
  BOTH
}

enum AnswerType {
  FILTER
  LIST
}

enum FilterType {
  COMPETITION
  NATIONALITY
  CLUB
  POSITION
  POSITION_CATEGORY
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlayerStatusFilter {
  ANY
  CURRENT_ONLY
  RETIRED_ONLY
}

// ─── Core domain models ───────────────────────────────────────────────────────

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  username               String    @unique
  passwordHash           String
  isVerified             Boolean   @default(false)
  mmr                    Int       @default(1000)
  gamesPlayed            Int       @default(0)
  wins                   Int       @default(0)
  offlineDisconnectCount Int       @default(0)
  lastDisconnectAt       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  role                   Role      @default(PLAYER)

  sentFriendRequests     Friendship[]       @relation("FriendRequestsSent")
  receivedFriendRequests Friendship[]       @relation("FriendRequestsReceived")
  offlinePenalties       OfflinePenalty[]
  answerSuggestions      AnswerSuggestion[]

  @@index([mmr])
}

model OfflinePenalty {
  id             String    @id @default(uuid())
  userId         String
  mmrLost        Int
  gameSessionId  String
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, acknowledgedAt])
  @@index([createdAt])
}

model Friendship {
  id        String           @id @default(uuid())
  userId    String
  friendId  String
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user   User @relation("FriendRequestsSent", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendRequestsReceived", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId, status])
  @@index([friendId, status])
}

// ─── Geography ────────────────────────────────────────────────────────────────

model Country {
  id   String @id // ISO 3166-1 alpha-3 code, e.g. "ENG", "ESP"
  name String

  clubs        Club[]
  competitions Competition[]
}

// ─── Competitions ─────────────────────────────────────────────────────────────

model Competition {
  id          String          @id @default(uuid())
  name        String
  type        CompetitionType
  countryCode String?
  region      Region?
  tier        Int?
  createdAt   DateTime        @default(now())
  createdBy   String?

  country          Country?          @relation(fields: [countryCode], references: [id])
  clubs            Club[]            @relation("ClubCurrentCompetition")
  clubCompetitions ClubCompetition[]
}

// ─── Clubs ────────────────────────────────────────────────────────────────────

model Club {
  id                   String   @id @default(uuid())
  name                 String
  aliases              String[] @default([])
  countryCode          String
  currentCompetitionId String?
  /// Denormalised flat list of competition names this club has ever been in.
  /// Kept as a GIN-indexed String[] for fast question-filtering queries,
  /// matching the same pattern as the old FootballPlayer.clubs array.
  competitions         String[] @default([])
  logoUrl              String?
  createdAt            DateTime @default(now())
  createdBy            String?

  country            Country           @relation(fields: [countryCode], references: [id])
  currentCompetition Competition?      @relation("ClubCurrentCompetition", fields: [currentCompetitionId], references: [id])
  currentPlayers     Player[]
  playerClubs        PlayerClub[]
  clubCompetitions   ClubCompetition[]

  @@index([competitions], type: Gin)
  @@index([name])
}

// ─── Club ↔ Competition join table ─────────────────────────────────────────────

model ClubCompetition {
  id            String @id @default(uuid())
  clubId        String
  competitionId String

  club        Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@unique([clubId, competitionId])
  @@index([clubId])
  @@index([competitionId])
}

// ─── Players ──────────────────────────────────────────────────────────────────

model Player {
  id              String         @id @default(uuid())
  firstName       String
  lastName        String
  /// Canonical display name (e.g. "Vinícius Júnior"). Fuzzy-searched via GIN + pg_trgm.
  name            String
  /// Known alternate names / nicknames. Fuzzy-searched via GIN + pg_trgm on the
  /// flattened string — identical index strategy to the old FootballPlayer.aliases.
  aliases         String[]       @default([])
  nationality     String // Country.id (ISO alpha-3)
  dateOfBirth     DateTime?
  heightCm        Int?
  preferredFoot   PreferredFoot?
  positionCategories PositionCategory[] @default([])
  positions       Position[]     @default([])
  primaryPosition Position?
  isRetired       Boolean        @default(false)
  currentClubId   String?
  imageUrl        String?
  /// Denormalised flat list of club names derived from PlayerClub history.
  /// GIN indexed. Do NOT set directly — use PlayerDenormService.regenerateForPlayer().
  clubs           String[]       @default([])
  /// Denormalised flat list of competition names derived from clubs[].competitions.
  /// GIN indexed. Do NOT set directly — use PlayerDenormService.regenerateForPlayer().
  competitions    String[]       @default([])
  createdAt       DateTime       @default(now())
  createdBy       String?

  currentClub     Club?              @relation(fields: [currentClubId], references: [id])
  playerClubs     PlayerClub[]
  questionPhotos  Question[]         @relation("QuestionPhotoPlayer")
  questionAnswers QuestionAnswer[]
  suggestions     AnswerSuggestion[]

  // GIN index on positions array for filter queries
  @@index([positions], type: Gin)
  @@index([positionCategories], type: Gin)
  // GIN index on clubs (denormalised) for fast filter queries
  @@index([clubs], type: Gin)
  // GIN index on competitions (denormalised) for fast filter queries
  @@index([competitions], type: Gin)
  @@index([name])
  @@index([currentClubId])
  @@index([nationality])
}

// ─── Player ↔ Club history ────────────────────────────────────────────────────

model PlayerClub {
  id        String  @id @default(uuid())
  playerId  String
  clubId    String
  startYear Int?
  /// null = ongoing / current club
  endYear   Int?
  isCurrent Boolean @default(false)

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([clubId])
}

// ─── Questions ────────────────────────────────────────────────────────────────

model Question {
  id                 String             @id @default(uuid())
  text               String
  gameMode           GameMode
  answerType         AnswerType
  scope              QuestionScope      @default(BOTH)
  logicOperator      LogicOperator? // applies when answerType = FILTER and there are >1 clauses
  photoPlayerId      String? // populated when gameMode = PHOTO_GUESS
  isActive           Boolean            @default(true)
  playerStatusFilter PlayerStatusFilter @default(ANY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  photoPlayer Player?                @relation("QuestionPhotoPlayer", fields: [photoPlayerId], references: [id])
  clauses     QuestionFilterClause[]
  answers     QuestionAnswer[]
  suggestions AnswerSuggestion[]

  @@index([gameMode])
  @@index([answerType])
  @@index([createdAt])
}

model QuestionFilterClause {
  id          String     @id @default(uuid())
  questionId  String
  filterType  FilterType
  filterValue String
  timeframe   Timeframe  @default(BOTH)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuestionAnswer {
  id         String  @id @default(uuid())
  questionId String
  playerId   String
  /// Rank (1-based) for TOP_10 questions; null for other modes.
  rank       Int?
  /// Human-readable slot label for LINEUP questions (e.g. "GK", "LB"); null for other modes.
  slotLabel  String?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([questionId, playerId])
  @@index([questionId])
  @@index([playerId])
}

// ─── Answer suggestion review queue ───────────────────────────────────────────

model AnswerSuggestion {
  id          String           @id @default(uuid())
  questionId  String
  guessText   String
  playerId    String?
  suggestedBy String
  status      SuggestionStatus @default(PENDING)
  comment     String?
  reviewNote  String?
  createdAt   DateTime         @default(now())
  reviewedAt  DateTime?

  question  Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  player    Player?  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  suggester User     @relation(fields: [suggestedBy], references: [id], onDelete: Cascade)

  @@index([questionId, status])
  @@index([suggestedBy])
}
